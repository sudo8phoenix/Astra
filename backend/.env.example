# ============================================================================
# AI ASSISTANT AGENT - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and populate with actual values for your environment
# DO NOT commit .env to version control

# ============================================================================
# 1. APPLICATION CONFIGURATION
# ============================================================================
APP_NAME="AI Personal Assistant API"
APP_ENV=development
# Options: development, staging, production
APP_DEBUG=True
API_PREFIX=/api
API_VERSION=v1
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ============================================================================
# 2. SERVER CONFIGURATION
# ============================================================================
HOST=0.0.0.0
PORT=8000
RELOAD=True
WORKERS=4

# ============================================================================
# 3. DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/ai_assistant_dev
# For SQLAlchemy async operations
DATABASE_ASYNC_URL=postgresql+asyncpg://user:password@localhost:5432/ai_assistant_dev
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_ECHO=False

# ============================================================================
# 4. REDIS CONFIGURATION (Session/Cache)
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1
REDIS_SESSION_TTL=3600
REDIS_CACHE_TTL=1800

# ============================================================================
# 5. AUTHENTICATION & SECURITY
# ============================================================================
# JWT Configuration
JWT_SECRET_KEY=your-very-secure-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# OAuth 2.0 - Google
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# OAuth 2.0 - GitHub (Optional)
GITHUB_OAUTH_CLIENT_ID=your-github-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-client-secret
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# CORS Configuration
FRONTEND_URL=http://localhost:3000

# ============================================================================
# 6. LLM & AI CONFIGURATION
# ============================================================================
# Groq API (Primary LLM Provider)
GROQ_API_KEY=your-groq-api-key
GROQ_PLANNER_MODEL=llama-3.3-70b-versatile
GROQ_EXECUTION_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Cost Management
LLM_DAILY_TOKEN_LIMIT=1000000
LLM_COST_THRESHOLD_CENTS=500

# ============================================================================
# 7. EXTERNAL API INTEGRATIONS
# ============================================================================
# Gmail API
GMAIL_API_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.send
GMAIL_MAX_RESULTS=10

# Google Calendar API
CALENDAR_API_SCOPES=https://www.googleapis.com/auth/calendar.readonly,https://www.googleapis.com/auth/calendar.events

# WhatsApp Business API (Optional)
WHATSAPP_BUSINESS_API_KEY=your-whatsapp-api-key
WHATSAPP_BUSINESS_PHONE_ID=your-phone-id

# OpenWeather API (Optional for context)
OPENWEATHER_API_KEY=your-openweather-api-key

# ============================================================================
# 8. LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json
# Options: text, json
LOG_OUTPUT=stdout,file
LOG_FILE_PATH=./logs/app.log
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

# ============================================================================
# 9. OBSERVABILITY & APM
# ============================================================================
# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Datadog (Optional APM)
DATADOG_ENABLED=False
DATADOG_SERVICE_NAME=ai-assistant-api
DATADOG_ENV=development

# Prometheus Metrics
METRICS_ENABLED=True
METRICS_PORT=8001

# ============================================================================
# 10. AUDIT & LOGGING
# ============================================================================
AUDIT_LOG_ENABLED=True
AUDIT_LOG_TABLE=audit_logs
# Options: debug, info, critical
AUDIT_LOG_LEVEL=info

# ============================================================================
# 11. FEATURE FLAGS
# ============================================================================
FEATURE_EMAIL_MANAGEMENT=True
FEATURE_CALENDAR_MANAGEMENT=True
FEATURE_TASK_MANAGEMENT=True
FEATURE_WHATSAPP_INTEGRATION=False

# ============================================================================
# 12. EMAIL CONFIGURATION (for system notifications)
# ============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SYSTEM_EMAIL=noreply@ai-assistant.local

# ============================================================================
# 13. ENVIRONMENT-SPECIFIC SETTINGS
# ============================================================================
# Development (local)
# Leave as provided above

# Staging
# DATABASE_URL=postgresql://user:password@staging-db:5432/ai_assistant_staging
# APP_DEBUG=False
# ALLOWED_ORIGINS=["https://staging.ai-assistant.local"]
# LOG_LEVEL=INFO

# Production
# DATABASE_URL=postgresql://user:password@prod-db:5432/ai_assistant_prod
# APP_DEBUG=False
# ALLOWED_ORIGINS=["https://ai-assistant.com"]
# LOG_LEVEL=WARNING
# JWT_SECRET_KEY=<use-secure-vault>
# GROQ_API_KEY=<use-secure-vault>
